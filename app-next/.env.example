# --- Sanity (public — safe to expose in client bundle) ---
# Get these from sanity.io/manage after you create a project, or run:
#   npx sanity@latest init
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Sanity API token — only needed if you enable draft preview / private datasets
SANITY_API_READ_TOKEN=

# --- Neon Postgres (via Vercel integration with custom prefix "SENSSTORAGE") ---
# Pulled automatically on Vercel deployments. For local dev, copy the Pooled
# connection string from your Neon dashboard.
SENSSTORAGE_URL=

# --- Auth.js ---
# Generate with: `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=

# Vercel sets this automatically. Locally, point at http://localhost:3000
# AUTH_URL=http://localhost:3000

# --- Owner bootstrap (one-time, used by `npm run seed:owner`) ---
# After seeding, you can remove these from .env.local.
OWNER_EMAIL=
OWNER_PASSWORD=

# --- Algolia (public search-only — used by SearchTrigger.tsx) ---
NEXT_PUBLIC_ALGOLIA_APP_ID=MCQLL7T01W
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=93f684841e21e29ec977fb25e364c2d1
NEXT_PUBLIC_ALGOLIA_INDEX=senscode_site
