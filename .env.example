# Algolia credentials
# Copy this file to .env and fill in real values. .env is gitignored.

# Public application id — safe to expose to the browser.
ALGOLIA_APP_ID=

# Search-only API key — safe to expose to the browser.
# Used by the frontend modal to query the index.
ALGOLIA_SEARCH_KEY=

# Admin API key — KEEP SECRET. Server-side only.
# Used by scripts/algolia-index.mjs to push records.
ALGOLIA_ADMIN_KEY=

# Index name. Defaults to "senscode_site".
ALGOLIA_INDEX_NAME=senscode_site
